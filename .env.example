# Copy to `.env` for local overrides. Local defaults already let the app boot with
# no setup — you only need these to change behaviour. Production values are set on Render.

# Debug mode. Keep true locally; MUST be false in production.
DEBUG=true

# Secret key. A dev fallback is baked in; production generates its own on Render.
SECRET_KEY=dev-insecure-key-do-not-use-in-prod

# Comma-separated hostnames Django will serve.
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Comma-separated origins allowed to call this API (the frontend).
CORS_ALLOWED_ORIGINS=http://localhost:4321,https://souhaibbenfarhat.github.io

# Database. Leave unset locally to use SQLite. In production this is a Postgres URL
# (set on Render). Example: postgres://user:pass@host:5432/dbname
# DATABASE_URL=

# --- AI chat ---------------------------------------------------------------
# The failover chain lives in the admin under "Chat models": drag the rows to choose
# which model answers (the top one) and the order the rest are tried in. These two vars
# are only the fallback for when that list is empty — a fresh deploy, or a wiped free
# database — so the chat still works before anything is configured. The provider prefix
# selects which key below is used.
CHAT_MODEL=mistral/mistral-small-latest
CHAT_FALLBACK_MODEL=mistral/open-mistral-nemo
# Sampling temperature — higher is more varied/conversational (0.0–1.0+).
CHAT_TEMPERATURE=0.7

# Free provider API keys. Mistral has a genuinely free tier that works in the EU
# (Gemini's free tier is limit:0 in the EEA). Get a key at console.mistral.ai.
# Groq (console.groq.com) is a free alternative. Set the real values on Render for
# production, or add them (encrypted) in the Django admin under "API credentials".
MISTRAL_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# Z.ai, for the GLM models. glm-4.7-flash is free (200k window, tool calling) and is
# seeded into the chain, switched off until this key exists. glm-5.2 is stronger but
# paid — add it as a row in the admin if you want it. Key: z.ai, no card required.
ZAI_API_KEY=

# GitHub, for the project/README tools. Username defaults to SouhaibBenFarhat.
# A token is optional (lifts the API rate limit); create a read-only one if needed.
GITHUB_USERNAME=SouhaibBenFarhat
GITHUB_TOKEN=

# Chat guardrails (optional — sensible defaults apply if unset).
# CHAT_MAX_MESSAGE_LENGTH=2000     # reject longer messages
# CHAT_MAX_HISTORY_MESSAGES=100    # how much history is sent to the model
# CHAT_RATE_LIMIT=10               # requests per IP per window
# CHAT_RATE_WINDOW_SECONDS=60      # the rate-limit window, in seconds

# Output guardrail — a second model call reviews each reply (scope + prompt-injection)
# before it streams to the client. See chat/guard.py.
# CHAT_GUARD_ENABLED=true          # turn the reply guard on/off
# CHAT_GUARD_MODEL=mistral/mistral-small-latest  # review model (defaults to CHAT_MODEL)
# CHAT_GUARD_MAX_CHARS=240         # buffer size per guard-checked chunk
