# Copy to `.env` for local overrides. Local defaults already let the app boot with
# no setup — you only need these to change behaviour. Production values are set on Render.

# Debug mode. Keep true locally; MUST be false in production.
DEBUG=true

# Secret key. A dev fallback is baked in; production generates its own on Render.
SECRET_KEY=dev-insecure-key-do-not-use-in-prod

# Comma-separated hostnames Django will serve.
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# Comma-separated origins allowed to call this API (the frontend).
CORS_ALLOWED_ORIGINS=http://localhost:4321,https://souhaibbenfarhat.github.io

# Database. Leave unset locally to use SQLite. In production this is a Postgres URL
# (set on Render). Example: postgres://user:pass@host:5432/dbname
# DATABASE_URL=

# --- AI chat ---------------------------------------------------------------
# LiteLLM model ids. The chat tries CHAT_MODEL first and falls back to
# CHAT_FALLBACK_MODEL if the first fails (e.g. free-tier quota). Provider prefix
# selects which key below is used.
CHAT_MODEL=gemini/gemini-2.5-flash
CHAT_FALLBACK_MODEL=gemini/gemini-2.5-flash-lite
# Sampling temperature — higher is more varied/conversational (0.0–1.0+).
CHAT_TEMPERATURE=0.7

# Free provider API keys. Get them at console.groq.com and aistudio.google.com.
# Needed locally to actually stream; set the real values on Render for production.
GROQ_API_KEY=
GEMINI_API_KEY=

# GitHub, for the project/README tools. Username defaults to SouhaibBenFarhat.
# A token is optional (lifts the API rate limit); create a read-only one if needed.
GITHUB_USERNAME=SouhaibBenFarhat
GITHUB_TOKEN=

# Chat guardrails (optional — sensible defaults apply if unset).
# CHAT_MAX_MESSAGE_LENGTH=2000     # reject longer messages
# CHAT_MAX_HISTORY_MESSAGES=20     # how much history is sent to the model
# CHAT_RATE_LIMIT=20               # requests per IP per window
# CHAT_RATE_WINDOW_SECONDS=600     # the rate-limit window
